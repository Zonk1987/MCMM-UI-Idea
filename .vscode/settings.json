{
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  "files.associations": {
    "*.page": "html"
  },

  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,

  "stylelint.enable": true,

  "stylelint.validate": ["css", "scss", "less", "postcss", "html", "php"],

  "editor.codeActionsOnSave": {
    "source.fixAll.stylelint": "explicit"
  }
}
