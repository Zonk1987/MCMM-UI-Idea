{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "HTML Validate",
      "type": "shell",
      "command": "npm run lint:html",
      "problemMatcher": {
        "owner": "html-validate",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+)\\s+(error|warning)\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    }
  ]
}
